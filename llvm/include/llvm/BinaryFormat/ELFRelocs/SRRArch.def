
#ifndef ELF_RELOC
#error "ELF_RELOC must be defined"
#endif

// No relocation
ELF_RELOC(R_SRRARCH_NONE,        0)
// General 32-bit relocation
ELF_RELOC(R_SRRARCH_32,            1)
// General 64-bit relocation
ELF_RELOC(R_SRRARCH_64,            2)
// Global 32-bit relocation
ELF_RELOC(R_SRRARCH_GV,            3)
